generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  transactions Transaction[]
  categories   Category[]
}

model Category {
  id        String   @id @default(uuid())
  name      String
  type      String
  userId    String
  user      User @relation(fields: [userId], references: [id])

  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Float
  type        String
  description String?
  date        DateTime

  userId      String
  user        User @relation(fields: [userId], references: [id])

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  createdAt   DateTime @default(now())
}