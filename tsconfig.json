{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true
  },

  "include": ["src", "prisma/seed.ts"],
  "exclude": ["node_modules"]
}